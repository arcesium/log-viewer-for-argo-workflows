{
    "manifest_version": 2,
    "name": "Log Viewer for Argo Workflows",
    "version": "1.1",
    "description": "Improves the log viewing experience in Argo Workflows UI",
    "permissions": [
        "scripting",
        "activeTab"
    ],
    "browser_action": {
        "default_icon": {
            "512": "icons/icon.png"
        }
    },
    "background": {
        "scripts": [
            "worker.js"
        ]
    },
    "web_accessible_resources": [
        "html/injected_footer.html",
        "css/styles.css"
    ]
}
