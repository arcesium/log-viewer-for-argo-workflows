{
    "manifest_version": 3,
    "name": "Log Viewer for Argo Workflows",
    "version": "1.1",
    "description": "Improves the log viewing experience in Argo Workflows UI",
    "permissions": [
        "scripting",
        "activeTab"
    ],
    "icons": {
        "512": "icons/icon.png"
    },
    "background": {
        "service_worker": "worker.js"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "html/injected_footer.html",
                "css/styles.css"
            ],
            "matches": [
                "*://*/*"
            ]
        }
    ],
    "action": {}
}
